<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IdeaPicker.MainPage"
             BackgroundColor="#FF83"
             Title="Date Night Picker">
             
    <StackLayout Padding="20,20">
        
        <!-- <Frame CornerRadius="12" Padding="12" BorderColor="LightCoral" -->
        <!--        <CollectionView ></CollectionView> -->
        
        
        <Label Text="Date" FontSize="Title" FontAttributes="Bold" Margin="0,10,0,10" />
    <Border Stroke="black" StrokeThickness="4">
        <Entry x:Name="txtDateNight" IsReadOnly="True"/>
    </Border>
    
    <Label Text="Date Description" FontSize="Title" FontAttributes="Bold" Margin="0,10,0,10" />
    <Border Stroke="black" StrokeThickness="4">
    <Entry x:Name="txtDateDescription" IsReadOnly="True" />
    </Border>
    
    <Button Text="Pick a Date Night!" FontSize="Title" Margin="0,80,0,0" Clicked="btnDatePicker_OnClicked" />
    
    </StackLayout>
</ContentPage>
